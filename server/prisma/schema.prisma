generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id           Int      @id @default(autoincrement())
  
  username     String   @unique @db.VarChar(40)
  email        String   @unique @db.VarChar(255)
  
  passwordHash String   @db.VarChar(255)

  role         Role     @default(CONTESTANT)
  rating       Int      @default(1500)

  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  problems              Problem[]
  submissions           Submission[]
  createdContests       Contest[]
  contestRegistrations  ContestRegistration[]
  contestStandings      ContestStanding[]
  editorials            Editorial[]
}

enum Role{
  ADMIN
  SETTER
  CONTESTANT
}
model Problem {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String   @db.Text
  difficulty  Difficulty @default(MEDIUM)

  tags        String   @db.Text  // "dp,graphs,greedy"

  authorId    Int
  author      User     @relation(fields: [authorId], references: [id])


  submissions Submission[]
  testCases       TestCase[]
  contestProblems ContestProblem[]
  editorial       Editorial?
}

enum Difficulty{
  EASY
  MEDIUM
  HARD
}

model TestCase {
  id             Int     @id @default(autoincrement())
  problemId      Int
  input          String  @db.Text
  expectedOutput String  @db.Text
  isSample       Boolean @default(false)
  orderIndex     Int     @default(0)

  problem        Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
}

model Submission {
  id          Int      @id @default(autoincrement())
  userId      Int
  problemId   Int
  contestId   Int?

  language    String
  code        String   @db.LongText

  status      Status   @default(PENDING)
  runtimeMs   Int?
  memoryKb    Int?
  score       Float?

  submittedAt DateTime @default(now())

  user        User    @relation(fields: [userId], references: [id])
  problem     Problem @relation(fields: [problemId], references: [id])

  @@index([userId])
  @@index([problemId])
  @@index([submittedAt])
}

enum Status { 
  PENDING 
  ACCEPTED 
  WRONG_ANSWER 
  TIME_LIMIT_EXCEEDED
  MEMORY_LIMIT_EXCEEDED 
  RUNTIME_ERROR 
  COMPILATION_ERROR 
}

model Contest {
  id          Int      @id @default(autoincrement())
  createdById Int

  title       String
  description String   @db.Text

  startTime   DateTime
  endTime     DateTime

  status      ContestStatus @default(UPCOMING)
  scoringType ScoringType @default(ICPC)

  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())

  createdBy             User                  @relation(fields: [createdById], references: [id])
  contestProblems       ContestProblem[]
  contestRegistrations  ContestRegistration[]
  contestStandings      ContestStanding[]

  @@index([startTime])
  @@index([endTime])
}

enum ContestStatus {
  UPCOMING
  LIVE
  ENDED
}

enum ScoringType { 
  ICPC 
  IOI 
}

model ContestProblem {
  contestId  Int
  problemId  Int
  points     Int @default(100)
  orderIndex Int @default(0)

  contest    Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  problem    Problem @relation(fields: [problemId], references: [id])

  @@id([contestId, problemId])
}

model ContestRegistration {
  contestId    Int
  userId       Int
  registeredAt DateTime @default(now())

  contest      Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user         User    @relation(fields: [userId], references: [id])

  @@id([contestId, userId])
}

model ContestStanding {
  contestId      Int
  userId         Int

  rank           Int?
  totalScore     Int      @default(0)

  solvedCount    Int      @default(0)
  penalty        Int      @default(0)

  lastSubmitTime DateTime?
  updatedAt      DateTime @updatedAt

  contest        Contest @relation(fields: [contestId], references: [id], onDelete: Cascade)
  user           User    @relation(fields: [userId], references: [id])

  @@id([contestId, userId])
  @@index([contestId])
  @@index([userId])
}

model Editorial { 
  id Int @id @default(autoincrement()) 
  problemId Int @unique 
  authorId Int 
  content String @db.LongText 
  publishedAt DateTime @default(now()) 
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade) 
  author User @relation(fields: [authorId], references: [id]) 
}

